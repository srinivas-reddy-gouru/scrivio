# Anthropic — required for all Claude-powered stages (brief, planning, drafting, editor, critic, polish)
ANTHROPIC_API_KEY=

# OpenAI — required for the claim verification agent (GPT-4o-mini)
OPENAI_API_KEY=

# Tavily — required when using Live web search mode
TAVILY_API_KEY=

# Set to "true" to route web fetches through the Jina Reader API (cleaner extraction on complex pages)
USE_JINA_READER=false

# Override the output directory (default: ./output)
# ARTICLE_OUTPUT_DIR=./output
